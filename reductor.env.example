PORT=8787
HOST=127.0.0.1
DEFAULT_PROVIDER=ollama
DEFAULT_BUDGET=balanced
OLLAMA_BASE_URL=http://127.0.0.1:11434
ENABLE_PROMPT_COMPRESSION=true
ENABLE_PERSISTENT_CACHE=true
ENABLE_METRICS_PERSIST=true
REQUESTS_PER_MINUTE=120
UPSTREAM_TIMEOUT_MS=120000

# Clés API optionnelles — laisser vide pour utiliser Ollama local gratuit
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
